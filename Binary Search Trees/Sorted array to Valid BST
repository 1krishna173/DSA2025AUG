class Solution {
  public:
    Node* helpher(vector<int> &arr,int start,int end){
        if(start>end){return NULL;}
        int mid=start+(end-start)/2;
        Node *currNode=new Node(arr[mid]);
        currNode->left=helpher(arr,start,mid-1);
        currNode->right=helpher(arr,mid+1,end);
        return currNode;
    }
    Node* sortedArrayToBST(vector<int>& arr) {
        // code here
        return helpher(arr,0,arr.size()-1);
    }
};
