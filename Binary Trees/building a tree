#include <bits/stdc++.h>
using namespace std;
class node{
    public: 
    int data;
    node* left;
    node* right;
    node(int data){
        this->data=data;
    }
};

static int idx=-1;
node* build(vector<int> nodes){
    idx++;
    if(nodes[idx]==-1){
        return NULL;
    }
    node* currnode=new node(nodes[idx]);
    currnode->left=build(nodes);
    currnode->right=build(nodes);
    return currnode;
}
int main() {
	vector<int> nodes={1,2,4,-1,-1,5,-1,-1,3,-1,6,-1,-1};
    node *root=build(nodes);
    cout<<root->data<<endl;
}
This is done using the pre order traversal

