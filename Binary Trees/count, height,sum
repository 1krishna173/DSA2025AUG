#include <bits/stdc++.h>
using namespace std;
class node{
    public: 
    int data;
    node* left;
    node* right;
    node(int data){
        this->data=data;
    }
};

static int idx=-1;
node* build(vector<int> nodes){
    idx++;
    if(nodes[idx]==-1){
        return NULL;
    }
    node* currnode=new node(nodes[idx]);  
    currnode->left=build(nodes);
    currnode->right=build(nodes);
    return currnode;
}

int height(node *root){
    if(root==NULL){return 0;}
    int lh=height(root->left);
    int rh=height(root->right);
    return max(lh,rh)+1;
}
int countnodes(node *root){
    if(root==NULL)return 0;
    int leftcount=countnodes(root->left);
    int rightcount=countnodes(root->right);
    return leftcount+rightcount+1;
}
int sum(node* root){
    if(root==NULL){return 0;}
    int lh=sum(root->left);
    int rh=sum(root->right);
    return lh+rh+root->data;
}
int main() {
	vector<int> nodes={1,2,4,-1,-1,5,-1,-1,3,-1,6,-1,-1};
    node *root=build(nodes);
    cout<<"Height of BT: "<<height(root)<<"  count of Nodes : "<<countnodes(root)<<"\n";
    cout<<"Sum of the BT: "<<sum(root);
}
