#include <bits/stdc++.h>
using namespace std;
class node{
    public: 
    int data;
    node* left;
    node* right;
    node(int data){
        this->data=data;
    }
};

static int idx=-1;
node* build(vector<int> nodes){
    idx++;
    if(nodes[idx]==-1){
        return NULL;
    }
    node* currnode=new node(nodes[idx]);  
    currnode->left=build(nodes);
    currnode->right=build(nodes);
    return currnode;
}

int height(node *root){
    if(root==NULL){return 0;}
    int lh=height(root->left);
    int rh=height(root->right);
    return max(lh,rh)+1;
}

int diameter(node* root){// TC-O(N*2)
    if(root==NULL){return 0;}
    int curr=height(root->left)+height(root->right)+1;
    int left=diameter(root->left);
    int right=diameter(root->right);
    return max(curr,max(left,right));
}
pair<int,int> diameter2(node *root){//TC-O(N)
    //(diameter,height);
    if(root==NULL)return make_pair(0,0);
    pair<int,int> left=diameter2(root->left);
    pair<int,int> right=diameter2(root->right);
    int currdia=(left.second+right.second)+1;
    int finaldia=max(currdia,max(left.first,right.first));
    int finalht=max(left.second,right.second)+1;
    return make_pair(finaldia,finalht);
}
int main() {
	vector<int> nodes={1,2,4,-1,-1,5,-1,-1,3,-1,6,-1,-1};
    node *root=build(nodes);
    cout<<"Diameter of BT : "<<diameter2(root).first<<" Height of BT: "<<diameter2(root).second;
    
}
