class Solution {
public:
    int optimus(int ind,int trans,int k,vector<int> &prices,vector<vector<int>> &dp){
        if(ind==prices.size())return 0;
        if(trans==2*k)return 0;
        if(dp[ind][trans]!=-1)return dp[ind][trans];
        long long profit=0;
        if(trans%2==0){
            profit=max(-prices[ind]+optimus(ind+1,trans+1,k,prices,dp),
            0+optimus(ind+1,trans,k,prices,dp));
        }
        else{
            profit=max(prices[ind]+optimus(ind+1,trans+1,k,prices,dp),
            0+optimus(ind+1,trans,k,prices,dp));
        }
        return dp[ind][trans]=profit;
    }
    int maxProfit(int k, vector<int>& prices) {
        int n=prices.size();
        vector<vector<int>> dp(n,vector<int> (2*k+1,-1));
        return optimus(0,0,k,prices,dp);
    }
};
