class Solution {
public:
    int findNumberOfLIS(vector<int>& arr) {
        int n=arr.size();
        if(n==1)return 1;
        vector<int> dp(n+1,1),cnt(n+1,1);
        int maxe=0;
        for(int i=1;i<n;i++){
            for(int j=0;j<i;j++){
                if(arr[i]>arr[j] and dp[j]+1>dp[i]){
                    dp[i]=dp[j]+1;
                    cnt[i]=cnt[j];
                }
                else if(arr[i]>arr[j] and dp[j]+1==dp[i]){
                    cnt[i]+=cnt[j];
                }
            }
            maxe=max(maxe,dp[i]);
        }
        int ans=0;
        for(int i=0;i<n;i++){
            if(dp[i]==maxe){
                ans+=cnt[i];
            }
        }
        return ans;
    }
};
