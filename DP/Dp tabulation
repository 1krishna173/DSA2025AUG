#include <bits/stdc++.h>
using namespace std;
// bottom- up appraoch 

int main() {
	int n;
	cin>>n;
    vector<int> dp(n+1,-1);
   dp[0]=0;
   dp[1]=1;
   for(int i=2;i<n;i++){
       dp[i]=dp[i-1]+dp[i-2];
   }
   cout<<dp[n];
    
}

#include <bits/stdc++.h>
using namespace std;
//Space optimization approach because we only meed last 2 values

int main() {
	int n;
	cin>>n;
    int prev1=0;
    int prev2=1;
    int curr=0;
    for(int i=2;i<=n;i++){
       curr=prev2+prev1;
       prev1=prev2;
       prev2=curr;
   }
   if(n==1){
       cout<<1<<endl;
   }
   cout<<curr;
    
}

