        if (dp[ind][buy] != -1)
            return dp[ind][buy];
        long long int p = 0;
        if (buy == 1) {
            p = max(-arr[ind] + f(ind + 1, 0, arr, dp), f(ind + 1, 1, arr, dp));
        } else {
            p = max(arr[ind] + f(ind + 1, 1, arr, dp), f(ind + 1, 0, arr, dp));
        }
        return dp[ind][buy] = p;
    }
    int maxProfit(vector<int>& arr) {
        int n = arr.size();
        vector<vector<int>> dp(n+1, vector<int>(2, 0));
        for (int ind = n - 1; ind >= 0; ind--) {
            for (int buy = 0; buy <= 1; buy++) {
                long long int p = 0;
                if (buy == 1) {
                    p = max(-arr[ind] +dp[ind+1][0],
                           dp[ind+1][1]);
                } else {
                    p = max(arr[ind] + dp[ind+1][1],
                            dp[ind+1][0]);
                }
                dp[ind][buy] = p;
            }
        }
        return dp[0][1];
        // return f(0, 1, arr, dp);
    }
};



