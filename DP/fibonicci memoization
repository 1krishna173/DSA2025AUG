#include <bits/stdc++.h>
using namespace std;
// memoization and top-down approach
int fib(int n,vector <int> &dp){
    if(n==1 || n==0){
        return n;
    }
    if(dp[n]!=-1){
        return dp[n];
    }
    dp[n]=fib(n-1,dp)+fib(n-2,dp);
    return dp[n];
}
int main() {
	// your code goes here
	int n;
	cin>>n;
    vector<int> dp(n+1,-1);
    cout<<fib(n,dp)<<endl;
    
}
#memoization :- it basically means that storing the value in it and using it further to reduce the complexity
SC_O(N) and TC:-O(N)
