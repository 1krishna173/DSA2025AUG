        vector<int> prev(m+1,0);
        int maxe=0;
        for(int i=1;i<=n;i++){
            vector<int> curr(m+1,0);
            for(int j=1;j<=m;j++){
                if(s1[i-1]==s2[j-1]){
                    curr[j]=1+prev[j-1];
                    maxe=max(maxe,curr[j]);
                }
                
            }
            prev=curr;
        }
        return maxe;
    }
};


