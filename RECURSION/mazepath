using namespace std;
int mazepath(int sr,int sc,int er,int ec){
    if(sr>er || sc>ec){return 0;}
    if(sr==er && sc==ec)return 1;
    int down=mazepath(sr,sc+1,er,ec);//right
    int right=mazepath(sr+1,sc,er,ec);//down
    int total=down+right;
    return total;
}
void printpath(int sr,int sc,int er,int ec,string s){
    if(sr>er || sc>ec){return ;}
    if(sr==er && sc==ec){
        cout<<s<<endl;
        return;
    }
    printpath(sr,sc+1,er,ec,s+'R');//right
    printpath(sr+1,sc,er,ec,s+'D');//down
}
int maze2(int er,int ec){
    if(er<1 || ec<1){
        return 0;
    }
    if(er==1 && ec==1)return 1;
    int down=maze2(er,ec-1);
    int right=maze2(er-1,ec);
    return down+right;
}
void printpath2(int er,int ec,string s){
    if(er<1 || ec<1)return;
    if(er==1 && ec==1){
        cout<<s<<endl;
        return;
    }
    printpath2(er,ec-1,s+'R');
    printpath2(er-1,ec,s+'D');
}
int main (){
    cout<<mazepath(1,1,3,3)<<endl;;
    string s="";
    printpath(1,1,3,3,s);
    cout<<maze2(3,3);
    string s2="";
    printpath2(3,3,s2);
    return 0;
}
