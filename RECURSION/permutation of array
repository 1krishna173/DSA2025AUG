#include <bits/stdc++.h>
using namespace std;
void permutation(vector<vector<int>> &ans,vector<int> arr,int i){
    if(i==arr.size()){ans.push_back(arr); return;}
    for(int j=i;j<arr.size();j++){
        swap(arr[i],arr[j]);
        permutation(ans,arr,i+1);
        swap(arr[i],arr[j]);
    }
    
}
int main() {
	// your code goes here
    vector<int> arr={1,2,3};
    vector<int> temp;
    vector<vector<int>> ans;
    permutation(ans,arr,0);
    for(int i=0;i<ans.size();i++){
        for(int j=0;j<ans[i].size();j++){
            cout<<ans[i][j]<<" ";
        }
        cout<<endl;
    }
}
